{
  "openapi": "3.1.0",
  "info": {
    "title": "MyTaskKing API",
    "version": "1.0.0",
    "description": "Enterprise collaboration platform \u2014 REST + Socket.IO. See /docs/API.md for full prose reference and /docs/ARCHITECTURE.md for system design."
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "auth"
    },
    {
      "name": "employees"
    },
    {
      "name": "clients"
    },
    {
      "name": "channels"
    },
    {
      "name": "chat"
    },
    {
      "name": "tasks"
    },
    {
      "name": "calls"
    },
    {
      "name": "telecaller"
    },
    {
      "name": "notifications"
    },
    {
      "name": "dashboard"
    },
    {
      "name": "files"
    },
    {
      "name": "audit"
    },
    {
      "name": "search"
    },
    {
      "name": "saved"
    },
    {
      "name": "settings"
    },
    {
      "name": "calendar"
    },
    {
      "name": "announcements"
    },
    {
      "name": "sessions"
    },
    {
      "name": "permissions"
    },
    {
      "name": "presence"
    },
    {
      "name": "analytics"
    },
    {
      "name": "automations"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {}
            }
          }
        }
      },
      "Envelope": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "data": {},
          "meta": {
            "type": "object"
          },
          "traceId": {
            "type": "string"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "SUPER_ADMIN",
              "ADMIN",
              "EMPLOYEE",
              "TELECALLER",
              "CLIENT"
            ]
          },
          "isClient": {
            "type": "boolean"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "SUSPENDED",
              "EXPIRED"
            ]
          }
        }
      },
      "Channel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "kind": {
            "type": "string",
            "enum": [
              "DM",
              "GROUP",
              "PROJECT",
              "ANNOUNCEMENT",
              "CLIENT"
            ]
          },
          "isClientChannel": {
            "type": "boolean"
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "channelId": {
            "type": "string"
          },
          "body": {
            "type": "string",
            "nullable": true
          },
          "threadRootId": {
            "type": "string",
            "nullable": true
          },
          "threadReplyCount": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "BACKLOG",
              "TODO",
              "IN_PROGRESS",
              "REVIEW",
              "DONE",
              "CANCELLED"
            ]
          },
          "priority": {
            "type": "string",
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "URGENT"
            ]
          },
          "dueAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/User"
          },
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "refreshExpiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RefreshRequest": {
        "type": "object",
        "required": [
          "refreshToken"
        ],
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "LogoutRequest": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ClientExtendRequest": {
        "type": "object",
        "properties": {
          "days": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of days to extend client access"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "Optional explicit expiry datetime"
          }
        }
      },
      "ChannelPolicyRequest": {
        "type": "object",
        "properties": {
          "defaultRole": {
            "type": "string"
          },
          "allowClientPosting": {
            "type": "boolean"
          },
          "allowFileUpload": {
            "type": "boolean"
          }
        }
      },
      "ChatMessageCreateRequest": {
        "type": "object",
        "properties": {
          "body": {
            "type": "string"
          },
          "threadRootId": {
            "type": "string",
            "nullable": true
          },
          "attachments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "TaskCreateRequest": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "URGENT"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "BACKLOG",
              "TODO",
              "IN_PROGRESS",
              "REVIEW",
              "DONE",
              "CANCELLED"
            ]
          },
          "dueAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "assigneeId": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "TaskMoveRequest": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "BACKLOG",
              "TODO",
              "IN_PROGRESS",
              "REVIEW",
              "DONE",
              "CANCELLED"
            ]
          },
          "position": {
            "type": "number",
            "nullable": true
          }
        }
      },
      "CallInitiateRequest": {
        "type": "object",
        "properties": {
          "channelId": {
            "type": "string"
          },
          "targetUserId": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "AUDIO",
              "VIDEO"
            ],
            "default": "AUDIO"
          }
        }
      },
      "RaiseHandRequest": {
        "type": "object",
        "properties": {
          "raised": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "LeadCreateRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "source": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "FileRegisterRequest": {
        "type": "object",
        "required": [
          "backend",
          "url",
          "mimeType",
          "size"
        ],
        "properties": {
          "backend": {
            "type": "string",
            "enum": [
              "CLOUDINARY",
              "R2"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "key": {
            "type": "string",
            "nullable": true
          },
          "mimeType": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          },
          "width": {
            "type": "integer",
            "nullable": true
          },
          "height": {
            "type": "integer",
            "nullable": true
          },
          "originalName": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "FilePolicyRequest": {
        "type": "object",
        "properties": {
          "visibility": {
            "type": "string",
            "enum": [
              "PRIVATE",
              "CHANNEL",
              "TENANT",
              "PUBLIC"
            ]
          },
          "channelId": {
            "type": "string",
            "nullable": true
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "watermark": {
            "type": "boolean"
          },
          "preventDownload": {
            "type": "boolean"
          }
        }
      },
      "CalendarEventCreateRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "startAt": {
            "type": "string",
            "format": "date-time"
          },
          "endAt": {
            "type": "string",
            "format": "date-time"
          },
          "allDay": {
            "type": "boolean"
          }
        }
      },
      "AnnouncementCreateRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "INFO",
              "IMPORTANT",
              "URGENT"
            ]
          }
        }
      },
      "PresenceUpdateRequest": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ONLINE",
              "AWAY",
              "DND",
              "OFFLINE"
            ]
          }
        }
      },
      "GrantCreateRequest": {
        "type": "object",
        "properties": {
          "subjectUserId": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "resourceType": {
            "type": "string"
          },
          "resourceId": {
            "type": "string",
            "nullable": true
          },
          "allow": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "AutomationCreateRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "trigger": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "config": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "responses": {
      "Error": {
        "description": "Error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "parameters": {
      "IdParam": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Resource identifier"
      },
      "ClientIdParam": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Client identifier"
      },
      "ChannelIdParam": {
        "name": "channelId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Channel identifier"
      },
      "RootIdParam": {
        "name": "rootId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Root message identifier"
      },
      "CallIdParam": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Call identifier"
      },
      "LeadIdParam": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Lead identifier"
      },
      "FileIdParam": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "File identifier"
      },
      "UserIdParam": {
        "name": "userId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "User identifier"
      },
      "AutomationIdParam": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Automation identifier"
      },
      "PageParam": {
        "name": "page",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "description": "Page number"
      },
      "PageSizeParam": {
        "name": "pageSize",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        },
        "description": "Items per page"
      },
      "SearchParam": {
        "name": "q",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Search query"
      },
      "StatusParam": {
        "name": "status",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Status filter"
      },
      "FromParam": {
        "name": "from",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date-time"
        },
        "description": "Range start in ISO datetime"
      },
      "ToParam": {
        "name": "to",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date-time"
        },
        "description": "Range end in ISO datetime"
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Liveness probe",
        "security": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Sign in with user id + password",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "userId",
                  "password"
                ],
                "properties": {
                  "userId": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Issued tokens",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Rotate refresh token",
        "security": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshRequest"
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Sign out",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LogoutRequest"
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Current user",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/employees": {
      "get": {
        "tags": [
          "employees"
        ],
        "summary": "List employees",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/PageSizeParam"
          },
          {
            "$ref": "#/components/parameters/SearchParam"
          }
        ]
      },
      "post": {
        "tags": [
          "employees"
        ],
        "summary": "Create employee",
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/clients": {
      "get": {
        "tags": [
          "clients"
        ],
        "summary": "List clients",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/PageSizeParam"
          },
          {
            "$ref": "#/components/parameters/SearchParam"
          }
        ]
      },
      "post": {
        "tags": [
          "clients"
        ],
        "summary": "Create client",
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/clients/{id}/extend": {
      "post": {
        "tags": [
          "clients"
        ],
        "summary": "Extend client access window",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/ClientIdParam"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientExtendRequest"
              }
            }
          }
        }
      }
    },
    "/channels": {
      "get": {
        "tags": [
          "channels"
        ],
        "summary": "Channels for the caller",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/PageSizeParam"
          },
          {
            "$ref": "#/components/parameters/SearchParam"
          }
        ]
      },
      "post": {
        "tags": [
          "channels"
        ],
        "summary": "Create channel",
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/channels/{id}/policy": {
      "patch": {
        "tags": [
          "channels"
        ],
        "summary": "Update channel-wide permission defaults",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/IdParam"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChannelPolicyRequest"
              }
            }
          }
        }
      }
    },
    "/chat/channels/{channelId}/messages": {
      "get": {
        "tags": [
          "chat"
        ],
        "summary": "Paged message history",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/ChannelIdParam"
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/PageSizeParam"
          }
        ]
      },
      "post": {
        "tags": [
          "chat"
        ],
        "summary": "Send message",
        "responses": {
          "201": {
            "description": "Created"
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/ChannelIdParam"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatMessageCreateRequest"
              }
            }
          }
        }
      }
    },
    "/chat/threads/{rootId}": {
      "get": {
        "tags": [
          "chat"
        ],
        "summary": "List a thread (root + replies)",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/RootIdParam"
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/PageSizeParam"
          }
        ]
      }
    },
    "/tasks": {
      "get": {
        "tags": [
          "tasks"
        ],
        "summary": "List or kanban view",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/PageSizeParam"
          },
          {
            "$ref": "#/components/parameters/SearchParam"
          },
          {
            "$ref": "#/components/parameters/StatusParam"
          }
        ]
      },
      "post": {
        "tags": [
          "tasks"
        ],
        "summary": "Create task",
