# --- core ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# --- database (postgres or mysql via Prisma) ---
DATABASE_URL=postgresql://bestie:bestie@localhost:5432/bestie?schema=public

# --- jwt ---
JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- cors / cdn ---
WEB_ORIGIN=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000

# --- redis (socket adapter + rate limit + bull) ---
# Leave blank to use the in-process cache + memory queue. Set when running
# behind a load balancer, or when you want BullMQ-backed job durability.
REDIS_URL=

# --- cloudinary (images) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- cloudflare R2 (files / pdfs) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bestie-files
R2_PUBLIC_BASE_URL=https://files.example.com

# --- agora (meetings / legacy — mobile 1:1 calls use mediasoup below) ---
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_TOKEN_TTL_SECONDS=3600

# --- mediasoup (connect.mytaskking.com — mobile voice/video calls) ---
MEDIASOUP_CONNECT_API_URL=https://connect.mytaskking.com
MEDIASOUP_SOCKET_URL=https://connect.mytaskking.com/public
MEDIASOUP_JOIN_SECRET=
MEDIASOUP_JOIN_TOKEN_TTL_SECONDS=7200

# --- exotel (telecaller) ---
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_VIRTUAL_NUMBER=
EXOTEL_CALLBACK_URL=https://api.example.com/api/v1/telecaller/webhook

# --- voice AI (telecaller recording analysis) ---
VOICE_AI_BASE_URL=https://ai.mytaskking.com
VOICE_AI_API_KEY=

# --- firebase admin (push) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Optional for local/dev: point to a Firebase Admin service-account JSON file
# instead of copying FIREBASE_CLIENT_EMAIL / FIREBASE_PRIVATE_KEY into .env.
FIREBASE_SERVICE_ACCOUNT_PATH=

# --- bootstrap super admin (used by `npm run seed`) ---
SEED_SUPER_ADMIN_USER_ID=superadmin
SEED_SUPER_ADMIN_PASSWORD=Change-Me-Now!
SEED_SUPER_ADMIN_NAME=Super Admin

# --- sales head (platform staff — org registration review) ---
SALES_HEAD_USER_ID=saleshead
SALES_HEAD_PASSWORD=SalesHead@123
SALES_HEAD_NAME=Sales Head
SALES_HEAD_EMAIL=sales@mytaskking.com

# --- email OTP (nodemailer) ---
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@mytaskking.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- razorpay (org subscriptions, INR) ---
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=REPLACE_ME
# Default plan prices (paise) — used only when seeding BillingPlan rows on first run
PLAN_1_MONTH_PAISE=99900
PLAN_6_MONTH_PAISE=499900
PLAN_12_MONTH_PAISE=899900

# --- multi-tenancy ---
MULTI_TENANT=true
DEFAULT_TENANT_ID=default

# --- background jobs ---
QUEUE_DRIVER=memory                  # memory | bullmq (requires REDIS_URL)
EVENT_TRANSPORT=memory               # memory | kafka | rabbitmq | sqs (only memory implemented today)

# --- search ---
SEARCH_ENGINE=postgres               # postgres | meilisearch | elasticsearch

# --- ai (opt-in; defaults to no-op) ---
AI_PROVIDER=noop                     # noop | anthropic | openai
AI_MODEL=
AI_API_KEY=

# --- monitoring ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
RELEASE_VERSION=

# --- security ---
FIELD_ENCRYPTION_KEY=                # 32-byte hex (64 chars). Required if any module encrypts fields.

# --- database read replica (optional) ---
READ_REPLICA_URL=
